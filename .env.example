# ── Server ────────────────────────────────────────────────────────────────
BIND_ADDRESS=0.0.0.0
PORT=8080
ASSETS_DIR=assets
WORKSPACE_DIR=tmp/workspace

# ── Database ──────────────────────────────────────────────────────────────
# If DATABASE_URL is unset, SQLite is used by default (a local file, schema
# created automatically at boot — zero config). Set a postgres:// URL to use
# PostgreSQL instead (manage its schema with dbmate; see README).
# DATABASE_URL=sqlite://pmp-iq.db?mode=rwc
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/pmp-iq
DATABASE_MAX_CONNECTIONS=10

# ── Authentication ────────────────────────────────────────────────────────
# If unset, an "admin" user with a random password is generated at boot and
# logged once.
# ADMIN_USER=admin
# ADMIN_PASS=change-me
SESSION_SECRET=dev-insecure-session-secret-change-me-please
# Base64-encoded 32-byte key used to encrypt secrets at rest.
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# ── Jobs ──────────────────────────────────────────────────────────────────
# Minimum interval (ms) between outbound GitHub/GitLab API calls (throttle to
# stay under rate limits). On a rate-limit response the review job self-pauses
# and the leader-elected controller resumes it once the limit resets.
GIT_API_MIN_INTERVAL_MS=250

# ── Assets ────────────────────────────────────────────────────────────────
# Cache-busting version appended to asset URLs (?v=...). If unset, a random
# value is generated per boot so local restarts invalidate stale assets.
# Set this to a build/release identifier in production.
# APP_VERSION=1.0.0

# ── Logging ───────────────────────────────────────────────────────────────
RUST_LOG=info,pmp_iq=debug
